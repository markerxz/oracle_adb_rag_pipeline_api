# ===================================
# KB Vector API - Environment Config
# Copy this file to .env and fill in
# ===================================

# Oracle Autonomous Database
DB_USER=ADMIN
DB_PASSWORD=your_oracle_db_password_here
DB_DSN=your_tns_alias_here          # e.g. mydb_high
DB_CONFIG_DIR=/path/to/your/wallet  # folder containing tnsnames.ora etc.

# OCI Object Storage
OCI_BUCKET_NAME=your_bucket_name_here

# AI Models (downloaded automatically via setup_models.py)
EMBEDDER_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Chunking (default words per chunk)
DEFAULT_CHUNK_SIZE=500
